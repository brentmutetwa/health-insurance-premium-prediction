    {
      "cell_type": "markdown",
      "source": [
        "**4. MODEL TRAINING**"
      ],
      "metadata": {
        "id": "5nM5IroeIrs4"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "**4.1 Splitting Test and Training Data**"
      ],
      "metadata": {
        "id": "RIoGIzToznOF"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#split dataframe into features (input) and target (output)\n",
        "X = df.drop(\"charges\", axis=1) #everything else except charges\n",
        "y = df[\"charges\"] #charges only\n",
        "\n",
        "#split model training and testing data: 20% testing and 80% training\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)"
      ],
      "metadata": {
        "id": "KtOPiH1OISlF"
      },
      "execution_count": 16,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "**4.2 Creating a Baseline \"Dumb\" Model**"
      ],
      "metadata": {
        "id": "wWnyVDTkzxbP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Simple baseline: predict mean\n",
        "baseline_pred = [y_train.mean()] * len(y_test)"
      ],
      "metadata": {
        "id": "-6OuLsQxz3G-"
      },
      "execution_count": 17,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "**4.3 Random Forest Model**"
      ],
      "metadata": {
        "id": "GelOJdjRz7KO"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "4.3.1 Fitting and Training Model"
      ],
      "metadata": {
        "id": "0babbCkP0CpH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#Fit and train model\n",
        "model = RandomForestRegressor(n_jobs=-1)\n",
        "model.fit(X_train, y_train)"
