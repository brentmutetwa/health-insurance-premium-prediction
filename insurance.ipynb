    {
      "cell_type": "code",
      "source": [
        "#Binary code the categorical variables \"sex\" and \"smoker\"\n",
        "\n",
        "df[\"sex\"] = df[\"sex\"].apply(lambda x: 1 if x == \"male\" else 0) #change \"male\" to 1 and \"female\" to 0\n",
        "df[\"smoker\"] = df[\"smoker\"].apply(lambda x: 1 if x == \"yes\" else 0) #change \"yes\" to 1 and \"no\" to 0\n",
        "df"
