      "cell_type": "code",
      "source": [
        "import ipywidgets as widgets\n",
        "from IPython.display import display, clear_output\n",
        "import numpy as np\n",
        "import pickle\n",
        "\n",
        "# Load trained model\n",
        "# Make sure 'rf_model.pkl' is uploaded to Colab\n",
        "model1 = pickle.load(open(\"rf_model.pkl\", \"rb\"))\n",
        "\n",
        "# Widgets for inputs\n",
        "age_widget = widgets.IntSlider(value=30, min=18, max=100, description=\"Age\")\n",
        "sex_widget = widgets.Dropdown(options=[\"M\", \"F\"], description=\"Sex\")\n",
        "bmi_widget = widgets.FloatSlider(value=25.0, min=10.0, max=60.0, step=0.1, description=\"BMI\")\n",
        "children_widget = widgets.IntSlider(value=0, min=0, max=10, step=1, description=\"Children\")\n",
        "smoker_widget = widgets.Dropdown(options=[\"Yes\", \"No\"], description=\"Smoker\")\n",
        "cardinal_widget = widgets.Dropdown(options=[\"NE\", \"NW\", \"SE\", \"SW\"], description=\"Cardinal\")\n",
        "\n",
        "# Output area\n",
        "output = widgets.Output()\n",
        "\n",
        "# Function to predict and display dynamically\n",
        "def update_prediction(change=None):\n",
        "    with output:\n",
        "        clear_output()\n",
        "\n",
        "        sex_encoded = 1 if sex_widget.value == \"M\" else 0\n",
        "        smoker_encoded = 1 if smoker_widget.value == \"Yes\" else 0\n",
        "        ne = 1 if cardinal_widget.value == \"NE\" else 0\n",
        "        nw = 1 if cardinal_widget.value == \"NW\" else 0\n",
        "        se = 1 if cardinal_widget.value == \"SE\" else 0\n",
        "        sw = 1 if cardinal_widget.value == \"SW\" else 0\n",
        "\n",
        "        input_features = np.array([[age_widget.value, sex_encoded, bmi_widget.value,\n",
        "                                    children_widget.value, smoker_encoded,\n",
        "                                    ne, nw, se, sw]])\n",
        "        prediction = model1.predict(input_features)\n",
        "        print(f\"Predicted Insurance Premium: ${prediction[0]:.2f}\")\n",
        "\n",
        "# Observe all widgets for changes\n",
        "for w in [age_widget, sex_widget, bmi_widget, children_widget, smoker_widget, cardinal_widget]:\n",
        "    w.observe(update_prediction, names='value')\n",
        "\n",
        "# Display widgets and output\n",
        "display(age_widget, sex_widget, bmi_widget, children_widget, smoker_widget, cardinal_widget, output)\n",
        "\n",
        "# Initialize with first prediction\n",
        "update_prediction()"
      ],
